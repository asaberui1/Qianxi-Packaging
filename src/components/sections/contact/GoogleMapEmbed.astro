---
const { lat = 30.86, lng = 104.41 } = Astro.props;
interface Props { lat?: number; lng?: number; }
---

<section class="py-20 bg-gray-50">
  <div class="mx-auto max-w-7xl px-4">
    <div class="overflow-hidden rounded-xl border-2 border-dashed border-gray-300 bg-gray-100 flex items-center justify-center" style="height: 400px;">
      <p class="text-center text-gray-400">
        <span class="block text-lg mb-2">📍 Google Maps</span>
        <span class="text-sm">Chengdu Qianxi Packaging Materials Co., Ltd.<br/>Jintang County, Chengdu, Sichuan, China</span>
        <span class="block mt-3 text-xs text-gray-300">(Map embed requires Google Maps API key — configure in window.QIANXI_CONFIG.googleMapsApiKey)</span>
      </p>
    </div>
  </div>
</section>
