---
import FooterSocialLink from '@components/ui/links/FooterSocialLink.astro';
import type { SiteTranslations } from '@/i18n/types';

const { t, lang = 'en' } = Astro.props;
interface Props {
  t: SiteTranslations;
  lang?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const prefix = lang === 'zh' ? '/zh' : '';
---

<footer class="bg-primary-900 text-white">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-5">
      <!-- Brand Column -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-600 text-lg font-extrabold text-white" style="font-family: var(--font-heading);">Q</span>
          <span class="text-lg font-bold text-white" style="font-family: var(--font-heading);">Qianxi Packaging</span>
        </div>
        <p class="text-sm text-gray-300 leading-relaxed max-w-sm">
          {t.footer.brandTagline}
        </p>
        <div class="flex gap-3 mt-6">
          <FooterSocialLink url="https://www.facebook.com/" icon="facebookFooter" />
          <FooterSocialLink url="https://twitter.com/" icon="xFooter" />
          <FooterSocialLink url="https://www.instagram.com/" icon="instagram" />
          <FooterSocialLink url="https://www.linkedin.com/" icon="linkedIn" />
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-accent-400" style="font-family: var(--font-heading);">{t.footer.quickLinks}</h4>
        <ul class="space-y-2">
          <li><a href={`${base}${prefix}/`} class="text-sm text-gray-300 hover:text-white transition">{t.nav.home}</a></li>
          <li><a href={`${base}${prefix}/about`} class="text-sm text-gray-300 hover:text-white transition">{t.nav.about}</a></li>
          <li><a href={`${base}${prefix}/products`} class="text-sm text-gray-300 hover:text-white transition">{t.nav.products}</a></li>
          <li><a href={`${base}${prefix}/contact`} class="text-sm text-gray-300 hover:text-white transition">{t.nav.contact}</a></li>
        </ul>
      </div>

      <!-- Products -->
      <div>
        <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-accent-400" style="font-family: var(--font-heading);">{t.footer.productLinks}</h4>
        <ul class="space-y-2">
          <li><a href={`${base}${prefix}/products`} class="text-sm text-gray-300 hover:text-white transition">{t.products.flute3layer}</a></li>
          <li><a href={`${base}${prefix}/products`} class="text-sm text-gray-300 hover:text-white transition">{t.products.flute5layer}</a></li>
          <li><a href={`${base}${prefix}/products`} class="text-sm text-gray-300 hover:text-white transition">{t.products.flute7layer}</a></li>
          <li><a href={`${base}${prefix}/products`} class="text-sm text-gray-300 hover:text-white transition">{t.products.fluteE}</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-accent-400" style="font-family: var(--font-heading);">{t.footer.support}</h4>
        <ul class="space-y-2">
          <li><a href={`${base}${prefix}/#faq`} class="text-sm text-gray-300 hover:text-white transition">FAQ</a></li>
          <li><a href={`${base}${prefix}/contact`} class="text-sm text-gray-300 hover:text-white transition">{t.nav.contact}</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 border-t border-primary-700 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-400">
        {t.footer.copyright}
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-xs text-gray-400 hover:text-white transition">{t.footer.privacyPolicy}</a>
        <a href="#" class="text-xs text-gray-400 hover:text-white transition">{t.footer.terms}</a>
      </div>
    </div>
  </div>
</footer>
