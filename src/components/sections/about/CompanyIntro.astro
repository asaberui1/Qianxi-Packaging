---
import ImagePlaceholder from '@components/ImagePlaceholder.astro';
import type { SiteTranslations } from '@/i18n/types';
const { t, lang = 'en' } = Astro.props;
interface Props { t: SiteTranslations; lang?: string; }
const isZh = lang === 'zh';
---

<section class="py-20">
  <div class="mx-auto max-w-7xl px-4">
    <!-- Intro Row -->
    <div class="grid items-start gap-12 lg:grid-cols-2">
      <div>
        <h1 class="mb-6 text-4xl font-extrabold text-primary-900" style="font-family: var(--font-heading);">
          {t.about.introHeading}
        </h1>
        <p class="mb-8 text-lg leading-relaxed text-gray-600">
          {t.about.introText}
        </p>
        <div class="grid grid-cols-3 gap-4">
          <div class="rounded-lg bg-gray-100 p-4 text-center">
            <div class="text-3xl font-extrabold text-accent-600" style="font-family: var(--font-heading);">XX+</div>
            <div class="mt-1 text-xs text-gray-500">{t.about.yearsExperience}</div>
          </div>
          <div class="rounded-lg bg-gray-100 p-4 text-center">
            <div class="text-3xl font-extrabold text-accent-600" style="font-family: var(--font-heading);">XX</div>
            <div class="mt-1 text-xs text-gray-500">{t.about.exportCountries}</div>
          </div>
          <div class="rounded-lg bg-gray-100 p-4 text-center">
            <div class="text-3xl font-extrabold text-accent-600" style="font-family: var(--font-heading);">XXk</div>
            <div class="mt-1 text-xs text-gray-500">{t.about.annualCapacity}</div>
          </div>
        </div>
      </div>
      <ImagePlaceholder label={isZh ? '[工厂外观照片]' : '[Factory exterior photo]'} height="h-80" />
    </div>

    <!-- Factory Details: Production Layout + Equipment -->
    <div class="mt-16 grid gap-8 lg:grid-cols-2">
      <!-- Production Layout -->
      <div class="rounded-xl border border-gray-200 bg-white p-8">
        <h3 class="mb-4 text-xl font-bold text-primary-800" style="font-family: var(--font-heading);">
          {isZh ? '生产线布局' : 'Production Layout'}
        </h3>
        <p class="mb-6 text-sm text-gray-600 leading-relaxed">
          {isZh
            ? '本项目主要在已建厂房基础上进行生产线布置和设备安装，不涉及土建工程。生产区位于车间北侧，自北向南依次布置：'
            : 'Production line layout and equipment installation within an existing factory building (no civil works). The production area occupies the north side of the workshop, arranged north to south:'}
        </p>
        <div class="grid grid-cols-2 gap-3 text-sm">
          {[
            ['印刷区', 'Printing Zone'],
            ['堆码区', 'Stacking Zone'],
            ['组装区', 'Assembly Zone'],
            ['打包区', 'Packing Zone'],
          ].map(([zh, en]) => (
            <div class="rounded-lg bg-gray-100 px-4 py-3 font-medium text-primary-800">{isZh ? zh : en}</div>
          ))}
        </div>
        <div class="mt-6 grid gap-3 text-sm">
          {[
            { zh: '原材料库 200 m²（北侧）', en: 'Raw Materials: 200 m² (North)' },
            { zh: '半成品区 80 m² + 预存区 100 m²（中部）', en: 'Semi-finished: 80 m² + Pre-storage: 100 m² (Central)' },
            { zh: '成品区 200 m²（南侧）', en: 'Finished Products: 200 m² (South)' },
            { zh: '辅料库 100 m²（东侧中部，储存白乳胶/油墨，重点防渗）', en: 'Auxiliary Storage: 100 m² (East-central, latex/ink, impermeable)' },
            { zh: '办公室 60 m² + 卫生间（东侧）', en: 'Office 60 m² + Restroom (East)' },
          ].map(item => (
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-accent-600">•</span>
              <span class="text-gray-600">{isZh ? item.zh : item.en}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Equipment + Environmental -->
      <div class="space-y-8">
        <!-- Equipment -->
        <div class="rounded-xl border border-gray-200 bg-white p-8">
          <h3 class="mb-4 text-xl font-bold text-primary-800" style="font-family: var(--font-heading);">
            {isZh ? '主要生产设备' : 'Main Equipment'}
          </h3>
          <div class="space-y-3 text-sm">
            {[
              { zh: '高速四色印刷模切开槽机（1228型）× 1', en: 'High-Speed 4-Color Printer Slotter (Model 1228) × 1' },
              { zh: '全自动粘钉一体机（2800型）× 1', en: 'Auto Gluer-Stitcher (Model 2800) × 1' },
              { zh: '堆码机（1228型）× 1', en: 'Stacker (Model 1228) × 1' },
              { zh: '全自动结束带打包机（1400型）× 1', en: 'Auto Strapping Machine (Model 1400) × 1' },
              { zh: '地牛叉车（3T）× 5', en: 'Pallet Jacks (3T) × 5' },
              { zh: '螺杆空压机（15kW）× 1', en: 'Screw Air Compressor (15kW) × 1' },
              { zh: '一体化污水处理装置（1T）× 1', en: 'Integrated Wastewater Treatment (1T) × 1' },
            ].map(item => (
              <div class="flex items-start gap-2">
                <span class="mt-0.5 text-accent-600">•</span>
                <span class="text-gray-600">{isZh ? item.zh : item.en}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Environmental -->
        <div class="rounded-xl border border-gray-200 bg-white p-8">
          <h3 class="mb-4 text-xl font-bold text-primary-800" style="font-family: var(--font-heading);">
            {isZh ? '环保合规' : 'Environmental Compliance'}
          </h3>
          <div class="space-y-3 text-sm">
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-accent-600">•</span>
              <span class="text-gray-600">{isZh ? '一般固废暂存区 10 m²，危废暂存间 5 m²（重点防渗）' : 'General waste 10 m² + Hazardous waste room 5 m² (impermeable)'}</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-accent-600">•</span>
              <span class="text-gray-600">{isZh ? '隔油池 0.5 m³ + 一体化废水处理系统 1 m³/天（印刷废水处理后回用）' : 'Oil separator 0.5 m³ + Integrated wastewater treatment 1 m³/day (printing water recycled)'}</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-accent-600">•</span>
              <span class="text-gray-600">{isZh ? '印刷/粘箱废气：集气罩 + 二级活性炭 + 15m排气筒（DA001）' : 'Printing/gluing exhaust: Hoods + 2-stage activated carbon + 15m stack (DA001)'}</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-accent-600">•</span>
              <span class="text-gray-600">{isZh ? '供水、供电及雨污管网依托园区既有设施' : 'Water, power, drainage via existing park infrastructure'}</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-accent-600">•</span>
              <span class="text-gray-600">{isZh ? '危废间和辅料库为新建重点防渗区，其余依托现有硬化地面' : 'Hazardous waste & aux materials zones: new impermeable; other areas: existing hardened flooring'}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Utility Info Line -->
    <p class="mt-8 text-center text-xs text-gray-400">
      {isZh
        ? '施工期主要影响：装修噪声、颗粒物及废包装材料。运营期主要影响：生产噪声、废边角料、危险废物、有机废气、粉尘、生活污水及清洗废水。'
        : 'Construction phase: renovation noise, particulates, waste packaging. Operation phase: production noise, scrap, hazardous waste, organic exhaust, dust, domestic/cleaning wastewater.'}
    </p>
  </div>
</section>
