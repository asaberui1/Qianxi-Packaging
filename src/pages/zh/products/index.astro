---
import MainLayout from '@/layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import ImagePlaceholder from '@components/ImagePlaceholder.astro';
import { getTranslations } from '@/i18n/utils';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const t = getTranslations('zh');
const products = await getCollection('products');
---

<MainLayout lang="zh">
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4">
      <h1 class="mb-12 text-center text-4xl font-extrabold text-primary-900" style="font-family: var(--font-heading);">
        {t.products.listTitle}
      </h1>
      <div class="flex gap-8">
        <!-- Sidebar -->
        <aside class="hidden w-56 shrink-0 lg:block">
          <div class="sticky top-24 space-y-6">
            <div>
              <h3 class="mb-3 text-sm font-bold text-primary-800" style="font-family: var(--font-heading);">{t.products.filterFluteType}</h3>
              <div class="space-y-2">
                <label class="flex items-center gap-2 text-sm text-gray-600"><input type="checkbox" class="rounded border-gray-300 text-accent-600 focus:ring-accent-500" /> {t.products.flute3layer}</label>
                <label class="flex items-center gap-2 text-sm text-gray-600"><input type="checkbox" class="rounded border-gray-300 text-accent-600 focus:ring-accent-500" /> {t.products.flute5layer}</label>
                <label class="flex items-center gap-2 text-sm text-gray-600"><input type="checkbox" class="rounded border-gray-300 text-accent-600 focus:ring-accent-500" /> {t.products.flute7layer}</label>
                <label class="flex items-center gap-2 text-sm text-gray-600"><input type="checkbox" class="rounded border-gray-300 text-accent-600 focus:ring-accent-500" /> {t.products.fluteE}</label>
              </div>
            </div>
            <div>
              <h3 class="mb-3 text-sm font-bold text-primary-800" style="font-family: var(--font-heading);">{t.products.filterUsage}</h3>
              <div class="space-y-2">
                <label class="flex items-center gap-2 text-sm text-gray-600"><input type="checkbox" class="rounded border-gray-300 text-accent-600 focus:ring-accent-500" /> {t.products.usageMoving}</label>
                <label class="flex items-center gap-2 text-sm text-gray-600"><input type="checkbox" class="rounded border-gray-300 text-accent-600 focus:ring-accent-500" /> {t.products.usageEcommerce}</label>
                <label class="flex items-center gap-2 text-sm text-gray-600"><input type="checkbox" class="rounded border-gray-300 text-accent-600 focus:ring-accent-500" /> {t.products.usageIndustrial}</label>
                <label class="flex items-center gap-2 text-sm text-gray-600"><input type="checkbox" class="rounded border-gray-300 text-accent-600 focus:ring-accent-500" /> {t.products.usageRetail}</label>
              </div>
            </div>
          </div>
        </aside>
        <!-- Product Grid -->
        <div class="flex-1">
          <div class="grid gap-6 sm:grid-cols-2">
            {products.map(product => (
              <a href={`${base}/zh/products/${product.data.main.id}`} class="group overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm transition hover:shadow-md">
                <ImagePlaceholder label={`[${product.data.title}]`} height="h-48" />
                <div class="p-4">
                  <h3 class="font-bold text-primary-800 group-hover:text-accent-600" style="font-family: var(--font-heading);">
                    {product.data.title}
                  </h3>
                  <p class="mt-1 text-sm text-gray-600">{product.data.description}</p>
                  <div class="mt-3 flex flex-wrap gap-2 text-xs">
                    <span class="rounded-full bg-gray-100 px-2 py-1 text-gray-600">{product.data.specs.fluteType}</span>
                    <span class="rounded-full bg-gray-100 px-2 py-1 text-gray-600">{product.data.specs.moq}</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
