---
import MainLayout from '@/layouts/MainLayout.astro';
import CompanyIntro from '@components/sections/about/CompanyIntro.astro';
import FactoryGallery from '@components/sections/about/FactoryGallery.astro';
import Certifications from '@components/sections/about/Certifications.astro';
import { getTranslations } from '@/i18n/utils';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const t = getTranslations('zh');
---

<MainLayout lang="zh">
  <CompanyIntro t={t} lang="zh" />
  <FactoryGallery t={t} />
  <Certifications t={t} />
  <section class="py-20">
    <div class="mx-auto max-w-4xl rounded-2xl bg-gray-100 px-6 py-12 text-center">
      <h2 class="mb-3 text-2xl font-extrabold text-primary-900" style="font-family: var(--font-heading);">
        {t.about.closingCTA}
      </h2>
      <p class="mb-6 text-gray-600">{t.about.closingCTASubtitle}</p>
      <a href={`${base}/zh/contact`} class="inline-block rounded-lg bg-accent-600 px-8 py-3 font-semibold text-white transition hover:bg-accent-700">
        {t.about.closingCTABtn} →
      </a>
    </div>
  </section>
</MainLayout>
